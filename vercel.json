{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "portfolio_website.html",
      "use": "@vercel/static"
    },
    {
      "src": "portfolio-data.json",
      "use": "@vercel/static"
    },
    {
      "src": "images/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/portfolio_website.html"
    },
    {
      "src": "/portfolio_website.html",
      "dest": "/portfolio_website.html"
    },
    {
      "src": "/portfolio-data.json",
      "dest": "/portfolio-data.json",
      "headers": {
        "Cache-Control": "public, max-age=0, must-revalidate"
      }
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/portfolio_website.html"
    }
  ]
}
